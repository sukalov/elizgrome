---
import { FONT_VARIANT_LIST, type FontVariantId } from '../data/font-variants';

interface Props {
  active: FontVariantId;
}

const { active } = Astro.props;
---

<nav
  class="font-preview-bar fixed inset-x-0 top-0 z-[60] border-b border-border bg-background/95 px-3 py-2 backdrop-blur-sm"
  aria-label="Font preview variants"
>
  <ul class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-3 gap-y-1 text-xs sm:text-sm">
    {FONT_VARIANT_LIST.map((variant) => (
      <li>
        <a
          href={variant.path}
          class:list={[
            'inline-block rounded px-2 py-1 no-underline hover:no-underline',
            variant.id === active
              ? 'bg-primary text-primary-foreground'
              : 'text-foreground hover:bg-muted',
          ]}
          aria-current={variant.id === active ? 'page' : undefined}
        >
          {variant.id === 'default' ? '/' : `/${variant.id}`}
          <span class="mx-1 opacity-50" aria-hidden="true">·</span>
          {variant.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  :global(body:has(.font-preview-bar) header[data-navbar-smooth-scroll]) {
    top: 2.75rem;
  }

  :global(body:has(.font-preview-bar) .about-hero-copy) {
    padding-top: 9.25rem;
  }

  @media (min-width: 768px) {
    :global(body:has(.font-preview-bar) .about-hero-copy) {
      padding-top: 10.25rem;
    }
  }
</style>
