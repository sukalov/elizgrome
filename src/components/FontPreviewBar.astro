---
import { FONT_VARIANT_LIST, type FontVariantId } from '../data/font-variants';

interface Props {
  active: FontVariantId;
}

const { active } = Astro.props;
---

<div class="font-preview-selector fixed bottom-4 right-4 z-[60]">
  <select
    id="font-variant-select"
    class="min-w-[11rem] max-w-[calc(100vw-2rem)] cursor-pointer rounded-lg border border-border bg-background px-3 py-2 font-serif text-sm leading-tight text-foreground shadow-[0_8px_24px_rgb(0_0_0/0.12)] outline-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
    aria-label="Choose font preview"
  >
    {FONT_VARIANT_LIST.map((variant) => (
      <option value={variant.path} selected={variant.id === active}>
        {variant.label}
      </option>
    ))}
  </select>
</div>

<script>
  const select = document.getElementById('font-variant-select');
  if (select instanceof HTMLSelectElement) {
    select.addEventListener('change', () => {
      if (select.value) window.location.assign(select.value);
    });
  }
</script>
