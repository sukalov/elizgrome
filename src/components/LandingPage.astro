---
import YAML from 'yaml';
import { ContactIconCloud } from './ContactIconCloud';
import { MerchCarousel } from './MerchCarousel';
import { SiteNavbar } from './SiteNavbar';
import landingRaw from '../content/landing.yaml?raw';
import logoSvg from '../assets/images/liza-logo.svg?raw';
import arrowTip from '../assets/images/arrow-tip.svg?url';
import pickFront from '../assets/images/pick-a.png';
import pickBack from '../assets/images/pick-b.png';
import { mergeLandingData, type CmsLanding, type Lang, type Localized } from '../data/landing-internal';
import Layout from '../layouts/Layout.astro';

const data = mergeLandingData(YAML.parse(landingRaw) as CmsLanding);
const images = import.meta.glob('../assets/images/*.{jpg,jpeg,png,webp}', {
  eager: true,
  import: 'default',
}) as Record<string, ImageMetadata>;

function imageSrc(path: string) {
  const key = path.replace('src/assets/images/', '../assets/images/');
  return images[key]?.src ?? path;
}

function localAttrs(value: Localized) {
  return {
    'data-i18n-en': value.en,
    'data-i18n-ru': value.ru,
  };
}

function phoneHref(value: string) {
  const normalized = value.replace(/[^\d+]/g, '');
  return normalized ? `tel:${normalized}` : undefined;
}

const about = data.sections.about;
const releases = data.sections.releases;
const concerts = data.sections.concerts;
const merch = data.sections.merch;
const contacts = data.sections.contacts;
const lang = 'en' as Lang;

const shirts = merch.groups.shirts.items.map((item) => ({
  ...item,
  image: imageSrc(item.image),
}));
const vinyl = merch.groups.vinyl.items.map((item) => ({
  ...item,
  image: imageSrc(item.image),
}));
const releaseYears = Array.from(new Set(releases.items.map((item) => item.year)))
  .sort((a, b) => Number(a) - Number(b));
const earlyReleaseYears = releaseYears.filter((year) => Number(year) < 2024 && year !== '2016' && year !== '2017');
const latestReleaseYears = releaseYears.filter((year) => Number(year) >= 2024);
const ozyoraTitle: Localized = { en: 'OZYORA', ru: 'ОЗЁРА' };
const earlyDotPositions = [0.08, 0.24, 0.4, 0.56, 0.72, 0.88];
const latestDotPositions = [0.42, 0.68, 0.8];
const timelineDots = [
  {
    id: 'ozera',
    year: '2016-2017',
    title: ozyoraTitle,
    modalId: 'ozera',
    page: 0,
    position: earlyDotPositions[0],
  },
  ...earlyReleaseYears.map((year, index) => ({
    id: `release-year-${year}`,
    year,
    title: null,
    modalId: `year-${year}`,
    page: 0,
    position: earlyDotPositions[index + 1] ?? 0.92,
  })),
  ...latestReleaseYears.map((year, index) => ({
    id: `release-year-${year}`,
    year,
    title: null,
    modalId: `year-${year}`,
    page: 1,
    position: latestDotPositions[index] ?? 0.84,
  })),
];
const releaseModalGroups = [
  {
    id: 'ozera',
    items: releases.items.filter((item) => item.year === '2016' || item.year === '2017'),
  },
  ...releaseYears.map((year) => ({
    id: `year-${year}`,
    items: releases.items.filter((item) => item.year === year),
  })),
].filter((group) => group.items.some((item) => item.image));

---

<Layout seo={data.site.seo}>
  <div id="top" class="min-h-screen overflow-x-clip bg-background text-foreground">
    <SiteNavbar
      client:load
      logo={data.site.navigation.logo}
      logoSvg={logoSvg}
      menuLabel={data.site.navigation.menu_label}
      searchLabel={data.site.navigation.search_label}
      languageLabel={data.site.navigation.language_label}
      promoPack={data.site.navigation.promo_pack}
      sectionLinks={data.site.navigation.section_links}
      searchSongs={data.search.songs}
    />

    <main>
      <section id="about" class="relative min-h-svh scroll-mt-11 overflow-hidden bg-background md:h-svh md:scroll-mt-12">
        <picture>
          <source media="(min-width: 768px)" srcset={imageSrc(about.hero.desktop)} />
          <img
            src={imageSrc(about.hero.mobile)}
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
          />
        </picture>
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 via-60% to-transparent"
          aria-hidden="true"
        ></div>
        <div class="pointer-events-none absolute inset-0 bg-white/15" aria-hidden="true"></div>
        <div class="about-hero-copy relative z-10 flex min-h-svh flex-col px-5 pb-8 pt-26 text-white md:h-svh md:px-10 md:pt-28">
          <div class="mt-auto max-w-2xl md:max-w-3xl">
            <h2
              id="about-title"
              class="font-heading text-5xl leading-none font-bold text-white md:text-6xl"
              {...localAttrs(about.title)}
            >
              {about.title[lang]}
            </h2>
            <p
              class="mt-4 max-w-xl whitespace-pre-line font-serif text-base leading-tight md:max-w-3xl md:text-[1.35rem]"
              {...localAttrs(about.text)}
            >
              {about.text[lang]}
            </p>
          </div>
        </div>
      </section>

      <section id="releases" class="releases-section min-h-svh scroll-mt-11 bg-background px-5 py-7 md:scroll-mt-12 md:px-10 md:py-8 lg:h-[200svh] lg:scroll-mt-0 lg:overflow-visible lg:px-0 lg:py-0">
        <div class="lg:hidden">
          <h2 class="font-heading text-5xl leading-none font-bold md:text-6xl" {...localAttrs(releases.title)}>
            {releases.title[lang]}
          </h2>
        </div>

        <div class="mt-7 grid gap-12 sm:px-8 lg:hidden">
          {releases.items.map((item) => (
            <article
              class:list={[
                'items-center justify-between gap-7 sm:gap-10 md:gap-8',
                item.image
                  ? 'grid grid-cols-[minmax(0,18.75rem)_8.5rem] sm:grid-cols-[18.75rem_13rem] md:grid-cols-[18.75rem_18rem]'
                  : 'grid grid-cols-[5rem_minmax(0,1fr)]',
              ]}
            >
              {item.image ? (
                <a href={item.url} class="block no-underline hover:no-underline">
                  <div class="rounded-md bg-background shadow-[0_18px_45px_rgb(0_0_0/0.12)]">
                    <img src={imageSrc(item.image)} alt={item.title[lang]} class="aspect-square w-full max-w-[18.75rem] rounded-md object-cover" loading="lazy" />
                  </div>
                </a>
              ) : (
                <p class="font-heading text-3xl leading-none text-foreground">
                  <span>{item.year}</span>
                </p>
              )}
              <div class={item.image ? 'text-right sm:pr-2' : 'min-w-0'}>
                {item.image && (
                  <p class="relative inline-block font-heading text-4xl leading-none text-foreground">
                    <span>{item.year}</span>
                  </p>
                )}
                <p class="mt-1 font-serif text-base leading-tight text-foreground sm:text-lg" {...localAttrs(item.title)}>
                  {item.title[lang]}
                </p>
              </div>
            </article>
          ))}
        </div>

        <div class="releases-timeline-sticky hidden lg:block">
          <h2 class="releases-timeline-title font-heading text-6xl leading-none font-bold" {...localAttrs(releases.title)}>
            {releases.title[lang]}
          </h2>

          <div class="releases-timeline-viewport" aria-label={releases.title[lang]}>
            <div class="releases-timeline-track">
              <div class="releases-timeline-start" aria-hidden="true"></div>
              <div class="releases-timeline-line" aria-hidden="true"></div>
              <div class="releases-timeline-dots">
                {timelineDots.map((dot) => (
                  <button
                    type="button"
                    class="releases-timeline-dot"
                    style={`--dot-page:${dot.page}; --dot-position:${dot.position};`}
                    aria-label={dot.title ? `${dot.title[lang]} ${dot.year}` : dot.year}
                    aria-haspopup="dialog"
                    data-release-modal-trigger={dot.modalId}
                  >
                    <span class="releases-timeline-dot-label">
                      {dot.title && (
                        <span class="releases-timeline-dot-title" {...localAttrs(dot.title)}>
                          {dot.title[lang]}
                        </span>
                      )}
                      <span class="releases-timeline-dot-year">{dot.year}</span>
                    </span>
                    <span class="releases-timeline-dot-mark" aria-hidden="true"></span>
                  </button>
                ))}
              </div>
              <img src={arrowTip} alt="" class="releases-timeline-arrow" aria-hidden="true" />
            </div>
          </div>
        </div>
      </section>

      <section id="concerts" class="min-h-svh scroll-mt-11 bg-background px-5 py-7 md:h-svh md:scroll-mt-12 md:overflow-hidden md:px-10 md:py-8">
        <h2 class="font-heading text-5xl leading-none font-bold md:text-6xl" {...localAttrs(concerts.title)}>
          {concerts.title[lang]}
        </h2>
        <div class="relative mt-4 min-h-[calc(100svh-9rem)] md:h-[calc(100%-4rem)] md:min-h-0">
          {concerts.items.map((item) => {
            const mobile = item.layout.mobile;
            const desktop = item.layout.desktop;
            return (
              <Fragment>
                <div
                  class:list={[
                    'absolute md:hidden',
                    item.style === 'primary' ? 'w-[12rem]' : 'w-[9.5rem]',
                  ]}
                  style={`left:${mobile.x}%; top:${mobile.y}%;`}
                >
                  {item.url ? (
                    <a href={item.url} class="block no-underline hover:text-primary hover:no-underline">
                      <span
                        class:list={[
                          'block font-serif leading-tight text-foreground',
                          item.style === 'primary' ? 'text-2xl' : 'text-xl text-primary',
                        ]}
                        {...localAttrs(item.title)}
                      >
                        {item.title[lang]}
                      </span>
                    </a>
                  ) : (
                    <span
                      class:list={[
                        'block font-serif leading-tight text-muted-foreground line-through',
                        item.style === 'primary' ? 'text-2xl' : 'text-xl',
                      ]}
                      {...localAttrs(item.title)}
                    >
                      {item.title[lang]}
                    </span>
                  )}
                </div>
                <div
                  class:list={[
                    'absolute hidden md:block',
                    item.style === 'primary' ? 'w-[18rem]' : 'w-[14rem]',
                  ]}
                  style={`left:${desktop.x}%; top:${desktop.y}%;`}
                >
                  {item.url ? (
                    <a href={item.url} class="block no-underline hover:text-primary hover:no-underline">
                      <span
                        class:list={[
                          'block font-serif leading-tight text-foreground',
                          item.style === 'primary' ? 'text-4xl' : 'text-2xl text-primary',
                        ]}
                        {...localAttrs(item.title)}
                      >
                        {item.title[lang]}
                      </span>
                    </a>
                  ) : (
                    <span
                      class:list={[
                        'block font-serif leading-tight text-muted-foreground line-through',
                        item.style === 'primary' ? 'text-4xl' : 'text-2xl',
                      ]}
                      {...localAttrs(item.title)}
                    >
                      {item.title[lang]}
                    </span>
                  )}
                </div>
              </Fragment>
            );
          })}
        </div>
      </section>

      <section id="merch" class="merch-section min-h-svh scroll-mt-11 bg-background px-5 py-7 md:h-[calc(100svh-3rem)] md:min-h-0 md:scroll-mt-12 md:overflow-hidden md:px-0 md:py-0">
        <div class="merch-stage relative mx-auto h-full md:mx-0 md:max-w-none">
          <h2 class="merch-title font-heading text-5xl leading-none font-bold md:text-5xl lg:text-6xl" {...localAttrs(merch.title)}>
            {merch.title[lang]}
          </h2>

          <div
            class="merch-pick"
            style={`--pick-front: url(${pickFront.src}); --pick-back: url(${pickBack.src});`}
            aria-label={merch.groups.picks.title[lang]}
            tabindex="0"
          >
            <div class="merch-pick-model" data-merch-pick-model>
              <span class="merch-pick-edge" aria-hidden="true"></span>
              <img class="merch-pick-side merch-pick-front" src={pickFront.src} alt="" loading="eager" />
              <img class="merch-pick-side merch-pick-back" src={pickBack.src} alt="" loading="eager" />
            </div>
          </div>

          <div class="merch-categories mt-6 hidden gap-2 md:mt-0 md:grid md:w-28 lg:w-32">
            <span class="font-serif text-sm leading-tight text-foreground lg:text-base" {...localAttrs(merch.groups.shirts.title)}>
              {merch.groups.shirts.title[lang]}
            </span>
            <span class="font-serif text-sm leading-tight text-foreground lg:text-base" {...localAttrs(merch.groups.vinyl.title)}>
              {merch.groups.vinyl.title[lang]}
            </span>
            <span class="font-serif text-sm leading-tight text-foreground lg:text-base" {...localAttrs(merch.groups.picks.title)}>
              {merch.groups.picks.title[lang]}
            </span>
          </div>

          <div id="merch-shirts" class="merch-shirts mt-8 md:mt-0">
            <h3 class="mb-3 font-serif text-xl leading-tight text-foreground md:hidden" {...localAttrs(merch.groups.shirts.title)}>
              {merch.groups.shirts.title[lang]}
            </h3>
            <MerchCarousel client:load items={shirts} lang={lang} desktopSingle fillHeight />
          </div>

          <div id="merch-vinyl" class="mt-10 md:hidden">
            <h3 class="mb-3 font-serif text-xl leading-tight text-foreground" {...localAttrs(merch.groups.vinyl.title)}>
              {merch.groups.vinyl.title[lang]}
            </h3>
            <MerchCarousel client:load items={vinyl} lang={lang} aspect="square" />
          </div>

          <div class="merch-vinyl-stripe hidden md:grid md:grid-cols-7 md:items-end md:gap-0">
            {vinyl.map((item) => (
              <figure>
                <img src={item.image} alt={item.alt[lang]} class="aspect-square w-full object-cover" loading="lazy" />
              </figure>
            ))}
          </div>

          <a
            href={merch.order_link.url}
            class="merch-order mx-auto mt-8 block w-fit font-serif text-2xl leading-tight text-foreground no-underline underline-offset-4  md:mx-0 md:mt-0 md:text-3xl lg:text-4xl hover:underline transition-all"
            {...localAttrs(merch.order_link.label)}
          >
            {merch.order_link.label[lang]}
        </a>
        </div>
      </section>

      <section id="contacts" class="relative h-[calc(100svh-2.75rem)] overflow-hidden scroll-mt-11 bg-background px-5 py-7 md:h-[calc(100svh-3rem)] md:scroll-mt-12 md:px-10 md:pb-8 md:pt-[31px]">
        <picture>
          <source media="(min-width: 768px)" srcset={imageSrc(contacts.hero.desktop)} />
          <img
            src={imageSrc(contacts.hero.mobile)}
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
        </picture>
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-black/35 via-45% to-black/10"
          aria-hidden="true"
        ></div>
        <div class="relative z-10 h-full text-white">
          <h2 class="font-heading text-5xl leading-none font-bold text-white md:text-6xl" {...localAttrs(contacts.title)}>
            {contacts.title[lang]}
          </h2>
          <div class="absolute inset-x-0 bottom-0 flex flex-col items-end gap-8 md:inset-x-auto md:left-0 md:right-0 md:grid md:grid-cols-[auto_1fr] md:items-end">
            <div class="w-fit">
              <ContactIconCloud client:load links={contacts.links} />
            </div>
            <address class="w-full text-right font-heading text-[clamp(1.375rem,6vw,2rem)] leading-[1.12] font-bold not-italic text-white md:justify-self-end md:text-[clamp(2rem,3.2vw,3rem)] md:leading-[1.08] lg:text-[clamp(2.75rem,4vw,5rem)]">
              <a href={`mailto:${contacts.email}`} class="block break-words text-white no-underline hover:text-white/80 hover:no-underline sm:whitespace-nowrap">
                {contacts.email}
              </a>
              <a href={phoneHref(contacts.phone)} class="block break-words text-white no-underline hover:text-white/80 hover:no-underline sm:whitespace-nowrap">
                {contacts.phone}
              </a>
            </address>
          </div>
        </div>
      </section>
    </main>

    <div class="release-modal-overlay" data-release-modal-overlay hidden>
      <div class="release-modal-backdrop" data-release-modal-close aria-hidden="true"></div>
      <section
        class="release-modal"
        role="dialog"
        aria-modal="true"
        aria-label={releases.title[lang]}
        tabindex="-1"
        data-release-modal
      >
        {releaseModalGroups.map((group) => (
          <div
            class="release-modal-grid"
            data-release-layout={group.items.length === 1 ? 'single' : group.items.length === 2 ? 'pair' : 'grid'}
            data-release-count={group.items.length}
            data-release-modal-panel={group.id}
            hidden
          >
            {group.items.map((item) => item.image && (
              <a href={item.url} class="release-modal-card" target="_blank" rel="noreferrer" aria-label={item.title[lang]}>
                <img src={imageSrc(item.image)} alt={item.title[lang]} class="release-modal-cover" loading="lazy" />
                <span class="release-modal-card-info">
                  <span class="release-modal-info-line" {...localAttrs(item.artist)}>{item.artist[lang]}</span>
                  <span class="release-modal-info-title" {...localAttrs(item.title)}>{item.title[lang]}</span>
                  <span class="release-modal-info-line">{item.year}</span>
                  {item.songs.length > 0 && (
                    <span class="release-modal-tracklist">
                      {item.songs.map((song) => (
                        <span {...localAttrs(song.title)}>{song.title[lang]}</span>
                      ))}
                    </span>
                  )}
                </span>
              </a>
            ))}
          </div>
        ))}
      </section>
    </div>
  </div>

  <style>
    .merch-pick {
      position: absolute;
      right: 0;
      top: 0;
      z-index: 1;
      display: block;
      width: clamp(5.5rem, 18vw, 9rem);
      perspective: 900px;
      touch-action: manipulation;
    }

    .merch-pick-model {
      position: relative;
      aspect-ratio: 0.9;
      transform: rotateX(12deg) rotateY(-22deg);
      transform-style: preserve-3d;
      will-change: transform;
      filter: drop-shadow(0 0.35rem 0.45rem rgb(0 0 0 / 0.08));
    }

    .merch-pick-side,
    .merch-pick-edge {
      position: absolute;
      inset: 0;
      display: block;
      height: 100%;
      width: 100%;
      object-fit: contain;
      backface-visibility: hidden;
      user-select: none;
      pointer-events: none;
    }

    .merch-pick-front {
      transform: translateZ(0.32rem);
      visibility: var(--pick-front-visible, visible);
    }

    .merch-pick-back {
      transform: translateZ(-0.32rem) scaleX(-1);
      visibility: var(--pick-back-visible, hidden);
    }

    .merch-pick-edge {
      background: linear-gradient(90deg, #1a1511, #6a5845 44%, #201912);
      -webkit-mask: var(--pick-front) center / contain no-repeat;
      mask: var(--pick-front) center / contain no-repeat;
      transform: translateZ(0);
      visibility: var(--pick-edge-visible, visible);
    }

    @media (min-width: 1024px) {
      .releases-section {
        --release-progress: 0;
        --releases-timeline-pad: 10rem;
        --releases-page-w: calc(100vw - var(--releases-timeline-pad));
        --releases-scroll-w: calc(120vw - var(--releases-timeline-pad));
      }

      .releases-timeline-sticky {
        position: sticky;
        top: 0;
        z-index: 1;
        height: 100svh;
        overflow: hidden;
        background: var(--background);
      }

      .releases-timeline-title {
        position: absolute;
        left: 2.5rem;
        top: 5rem;
        z-index: 2;
      }

      .releases-timeline-viewport {
        position: absolute;
        inset: 0;
        overflow: hidden;
      }

      .releases-timeline-track {
        position: absolute;
        left: var(--releases-timeline-pad);
        top: 50%;
        height: 0;
        width: calc(200vw - (var(--releases-timeline-pad) * 2));
        transform: translate3d(calc(var(--release-progress) * -1 * var(--releases-scroll-w)), 0, 0);
        will-change: transform;
      }

      .releases-timeline-line {
        position: absolute;
        left: 0.5rem;
        right: 20rem;
        top: 0;
        height: 2px;
        background: var(--foreground);
      }

      .releases-timeline-dots {
        position: absolute;
        inset: 0;
      }

      .releases-timeline-dot {
        --timeline-dot-line-y: 4rem;
        appearance: none;
        border: 0;
        padding: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        position: absolute;
        left: calc(
          (var(--dot-page) * var(--releases-page-w)) +
          (var(--dot-position) * (var(--releases-page-w) - 7rem)) +
          2rem
        );
        top: calc(-1 * var(--timeline-dot-line-y));
        display: block;
        min-width: 5.25rem;
        height: 4.8rem;
        transform: translateX(-50%);
        cursor: pointer;
      }

      .releases-timeline-dot-label {
        position: absolute;
        left: 50%;
        top: 0.35rem;
        display: grid;
        justify-items: center;
        gap: 0.3rem;
        transform: translateX(-50%);
        color: var(--primary);
        font-family: var(--site-font-family);
        font-weight: 500;
        line-height: 1;
        text-align: center;
        white-space: nowrap;
        transition: color 160ms ease, transform 160ms ease;
      }

      .releases-timeline-dot:hover .releases-timeline-dot-label,
      .releases-timeline-dot:focus-visible .releases-timeline-dot-label {
        transform: translate(-50%, -0.12rem);
        color: var(--foreground);
      }

      .releases-timeline-dot:focus-visible {
        outline: 0;
      }

      .releases-timeline-dot-title {
        font-size: 0.88rem;
        letter-spacing: 0;
      }

      .releases-timeline-dot-year {
        font-family: var(--site-font-family);
        font-size: 1rem;
        font-weight: 400;
        letter-spacing: 0;
      }

      .releases-timeline-dot-mark {
        position: absolute;
        left: 50%;
        top: var(--timeline-dot-line-y);
        height: 1rem;
        width: 1rem;
        transform: translate(-50%, -50%);
        border-radius: 9999px;
        background: var(--foreground);
        transition: transform 160ms ease, background 160ms ease, box-shadow 160ms ease;
      }

      .releases-timeline-dot:hover .releases-timeline-dot-mark,
      .releases-timeline-dot:focus-visible .releases-timeline-dot-mark {
        transform: translate(-50%, -50%) scale(1.14);
        background: var(--primary);
        box-shadow: 0 0 0 0.22rem rgb(0 0 0 / 0.06);
      }

      .releases-timeline-start {
        position: absolute;
        left: 0;
        top: 0;
        z-index: 1;
        height: 0.875rem;
        width: 0.875rem;
        transform: translateY(-50%);
        border: 2px solid var(--foreground);
        border-radius: 9999px;
        background: var(--background);
      }

      .releases-timeline-arrow {
        position: absolute;
        right: 20rem;
        top: 0;
        /* arrow tip size */
        width: 1.5rem;
        height: 1.5rem;
        transform: translate(50%, -50%) rotate(90deg);
      }

    }

    .release-modal-overlay {
      position: fixed;
      inset: 0;
      z-index: 60;
      display: grid;
      place-items: center;
      padding: clamp(1.25rem, 4vw, 4rem);
    }

    .release-modal-overlay[hidden] {
      display: none;
    }

    .release-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgb(0 0 0 / 0.78);
    }

    .release-modal {
      position: relative;
      width: min(68rem, calc(100vw - 8rem));
      max-height: calc(100svh - 8rem);
      overflow: auto;
      background: transparent;
      pointer-events: none;
    }

    .release-modal:focus {
      outline: 0;
    }

    .release-modal-grid {
      justify-content: center;
      gap: clamp(1.25rem, 3vw, 2.5rem);
      pointer-events: none;
    }

    .release-modal-grid:not([hidden]) {
      display: grid;
    }

    .release-modal-grid[data-release-layout="single"] {
      grid-template-columns: minmax(0, min(36rem, 72svh, 72vw));
    }

    .release-modal-grid[data-release-layout="pair"] {
      grid-template-columns: repeat(2, minmax(0, min(30rem, 38vw, 66svh)));
    }

    .release-modal-grid[data-release-layout="grid"] {
      grid-template-columns: repeat(3, minmax(0, min(20rem, 27vw, 36svh)));
      justify-content: start;
    }

    .release-modal-grid[data-release-count="3"] .release-modal-card:nth-child(3) {
      grid-column: 1;
      grid-row: 2;
    }

    .release-modal-card {
      display: block;
      position: relative;
      overflow: hidden;
      border-radius: 0.75rem;
      text-decoration: none;
      pointer-events: auto;
    }

    .release-modal-card:hover,
    .release-modal-card:focus-visible {
      text-decoration: none;
      outline: 0;
    }

    .release-modal-cover {
      aspect-ratio: 1;
      width: 100%;
      border-radius: 0.75rem;
      object-fit: cover;
      background: transparent;
      transition: filter 160ms ease, opacity 160ms ease;
    }

    .release-modal-card:hover .release-modal-cover,
    .release-modal-card:focus-visible .release-modal-cover {
      filter: brightness(0.34);
    }

    .release-modal-card-info {
      position: absolute;
      inset: 0;
      display: grid;
      align-content: center;
      gap: 0.35rem;
      overflow: auto;
      padding: clamp(1rem, 2vw, 1.5rem);
      color: white;
      opacity: 0;
      transition: opacity 160ms ease;
    }

    .release-modal-card:hover .release-modal-card-info,
    .release-modal-card:focus-visible .release-modal-card-info {
      opacity: 1;
    }

    .release-modal-info-line {
      display: block;
      font-size: clamp(0.85rem, 1.2vw, 1rem);
      line-height: 1.1;
    }

    .release-modal-info-title {
      display: block;
      font-size: clamp(1.1rem, 1.8vw, 1.55rem);
      font-weight: 700;
      line-height: 1.05;
    }

    .release-modal-tracklist {
      display: grid;
      gap: 0.15rem;
      margin-top: 0.4rem;
      font-size: clamp(0.78rem, 1vw, 0.9rem);
      line-height: 1.08;
    }

    @media (max-width: 1023px) {
      .release-modal-overlay {
        display: none;
      }
    }

    @media (min-width: 768px) {
      .merch-stage {
        --merch-section-h: calc(100svh - 3rem);
        --merch-pad: clamp(1rem, 3svh, 2rem);
        --vinyl-size: calc(100vw / 7);
        --carousel-top: var(--merch-pad);
        --carousel-bottom: var(--merch-pad);
        --carousel-h: min(
          clamp(24rem, 66svh, 40rem),
          calc(var(--merch-section-h) - var(--vinyl-size) - var(--carousel-top) - var(--carousel-bottom))
        );
        --carousel-w: min(
          calc(var(--carousel-h) * 0.8),
          56vw,
          calc(100vw - (var(--merch-pad) * 2) - 20rem)
        );
        --diagonal-gap: clamp(1.75rem, 4vw, 4.5rem);
      }

      .merch-title {
        position: absolute;
        left: calc(var(--merch-pad) + var(--carousel-w) + var(--diagonal-gap));
        top: var(--carousel-top);
        max-width: calc(100vw - var(--merch-pad) - var(--carousel-w) - var(--diagonal-gap) - 10rem);
      }

      .merch-shirts {
        position: absolute;
        left: var(--merch-pad);
        top: var(--carousel-top);
        height: var(--carousel-h);
        width: var(--carousel-w);
        min-height: 0;
      }

      .merch-categories {
        position: absolute;
        left: calc(var(--merch-pad) + var(--carousel-w) + ((100vw - var(--merch-pad) - var(--carousel-w)) / 2));
        top: calc((100% - var(--vinyl-size)) * 0.48);
        transform: translate(-50%, -50%);
      }

      .merch-order {
        position: absolute;
        right: var(--merch-pad);
        bottom: calc(var(--vinyl-size) + var(--diagonal-gap));
      }

      .merch-vinyl-stripe {
        position: absolute;
        inset-inline: 0;
        bottom: 0;
        height: var(--vinyl-size);
        width: 100vw;
      }

      .merch-vinyl-stripe figure,
      .merch-vinyl-stripe img {
        height: 100%;
      }

      .merch-pick {
        position: absolute;
        right: var(--merch-pad);
        top: var(--merch-pad);
      }
    }
  </style>

  <script>
    type Lang = 'en' | 'ru';

    const translated = document.querySelectorAll<HTMLElement>('[data-i18n-en][data-i18n-ru]');
    const toggles = document.querySelectorAll<HTMLElement>('[data-language-toggle]');
    const releasesSection = document.querySelector<HTMLElement>('.releases-section');
    const releaseModalOverlay = document.querySelector<HTMLElement>('[data-release-modal-overlay]');
    const releaseModal = document.querySelector<HTMLElement>('[data-release-modal]');
    const releaseModalPanels = document.querySelectorAll<HTMLElement>('[data-release-modal-panel]');
    const releaseModalTriggers = document.querySelectorAll<HTMLButtonElement>('[data-release-modal-trigger]');
    const releaseModalCloseNodes = document.querySelectorAll<HTMLElement>('[data-release-modal-close]');
    const pickModel = document.querySelector<HTMLElement>('[data-merch-pick-model]');
    const pick = pickModel?.closest<HTMLElement>('.merch-pick');
    const desktopTimelineQuery = window.matchMedia('(min-width: 1024px)');
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let releaseTimelineFrame = 0;
    let pickFrame = 0;
    let pickRotation = -22;
    let pickPreviousTime = 0;
    let releaseModalLastFocus: HTMLElement | null = null;

    function setLanguage(lang: Lang) {
      document.documentElement.lang = lang;
      localStorage.setItem('elizgrome-lang', lang);

      translated.forEach((node) => {
        if (node.closest('header')) return;

        node.textContent = node.dataset[`i18n${lang === 'ru' ? 'Ru' : 'En'}`] || '';
      });

      document.querySelectorAll<HTMLMetaElement>('[data-seo-description], [data-seo-description-og]').forEach((node) => {
        node.content = node.dataset[lang] || node.content;
      });
      document.querySelectorAll<HTMLMetaElement>('[data-seo-title]').forEach((node) => {
        node.content = node.dataset[lang] || node.content;
      });
      const title = document.querySelector<HTMLTitleElement>('[data-page-title]');
      if (title) title.textContent = title.dataset[lang] || title.textContent;
    }

    function switchLanguage(lang: Lang) {
      setLanguage(lang);
      window.dispatchEvent(new CustomEvent('elizgrome:set-language', { detail: lang }));
    }

    function scaleValue(value: number, from: [number, number], to: [number, number]) {
      const scale = (to[1] - to[0]) / (from[1] - from[0]);
      const capped = Math.min(from[1], Math.max(from[0], value)) - from[0];

      return capped * scale + to[0];
    }

    function animateValue(targetElement: HTMLElement | null, scrollPercentage: [number, number], animateRange: [number, number]) {
      if (!targetElement) return 0;

      return scaleValue(
        ((window.scrollY - targetElement.offsetTop) / targetElement.clientHeight) * 100,
        scrollPercentage,
        animateRange,
      );
    }

    function updateReleaseTimeline() {
      if (!releasesSection) return;

      if (!desktopTimelineQuery.matches) {
        releasesSection.style.removeProperty('--release-progress');
        return;
      }

      releasesSection.style.setProperty(
        '--release-progress',
        animateValue(releasesSection, [0, 50], [0, 1]).toString(),
      );
    }

    function queueReleaseTimelineUpdate() {
      if (releaseTimelineFrame) return;

      releaseTimelineFrame = window.requestAnimationFrame(() => {
        releaseTimelineFrame = 0;
        updateReleaseTimeline();
      });
    }

    function spinPick(time: number) {
      if (!pickModel) return;

      if (pickPreviousTime) pickRotation += ((time - pickPreviousTime) / 1000) * 42;
      pickPreviousTime = time;
      pickModel.style.transform = `rotateX(12deg) rotateY(${pickRotation}deg)`;
      const normalizedRotation = ((pickRotation % 360) + 360) % 360;
      const backVisible = normalizedRotation > 90 && normalizedRotation < 270;
      pickModel.style.setProperty('--pick-front-visible', backVisible ? 'hidden' : 'visible');
      pickModel.style.setProperty('--pick-back-visible', backVisible ? 'visible' : 'hidden');
      pickModel.style.setProperty('--pick-edge-visible', backVisible ? 'hidden' : 'visible');
      pickFrame = window.requestAnimationFrame(spinPick);
    }

    function startPickSpin() {
      if (!pickModel || pickFrame || reducedMotionQuery.matches) return;

      pickPreviousTime = 0;
      pickFrame = window.requestAnimationFrame(spinPick);
    }

    function stopPickSpin() {
      if (!pickFrame) return;

      window.cancelAnimationFrame(pickFrame);
      pickFrame = 0;
      pickPreviousTime = 0;
    }

    function setReleaseModalOpen(open: boolean) {
      if (!releaseModalOverlay) return;

      releaseModalOverlay.hidden = !open;
      document.documentElement.style.overflow = open ? 'hidden' : '';
    }

    function closeReleaseModal() {
      setReleaseModalOpen(false);
      releaseModalPanels.forEach((panel) => {
        panel.hidden = true;
      });
      releaseModalLastFocus?.focus();
      releaseModalLastFocus = null;
    }

    function openReleaseModal(groupId: string, trigger: HTMLElement) {
      if (!releaseModalOverlay || !releaseModal) return;

      const panel = Array.from(releaseModalPanels).find((item) => item.dataset.releaseModalPanel === groupId);
      if (!panel) return;

      releaseModalPanels.forEach((item) => {
        item.hidden = item !== panel;
      });

      releaseModalLastFocus = trigger;
      setReleaseModalOpen(true);
      releaseModal.focus({ preventScroll: true });
    }

    function setScrollTop(top: number) {
      const scrollingElement = document.scrollingElement || document.documentElement;

      scrollingElement.scrollTop = top;
      document.documentElement.scrollTop = top;
      document.body.scrollTop = top;
    }

    function scrollToHash(hash: string, updateHistory = true) {
      const id = hash.replace(/^#/, '');
      if (!id) return;

      const target = document.getElementById(id);
      if (!target) return;

      const scrollMarginTop = Number.parseFloat(window.getComputedStyle(target).scrollMarginTop) || 0;
      const top = target.getBoundingClientRect().top + window.scrollY - scrollMarginTop;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduceMotion) {
        setScrollTop(top);
      } else {
        window.scrollTo({ top, behavior: 'smooth' });
      }

      if (updateHistory) window.history.pushState(null, '', `#${id}`);
    }

    window.addEventListener('scroll', queueReleaseTimelineUpdate, { passive: true });
    window.addEventListener('resize', queueReleaseTimelineUpdate);
    desktopTimelineQuery.addEventListener('change', queueReleaseTimelineUpdate);
    pick?.addEventListener('pointerenter', startPickSpin);
    pick?.addEventListener('pointerleave', stopPickSpin);
    pick?.addEventListener('focus', startPickSpin);
    pick?.addEventListener('blur', stopPickSpin);
    releaseModalTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        openReleaseModal(trigger.dataset.releaseModalTrigger || '', trigger);
      });
    });
    releaseModalCloseNodes.forEach((node) => {
      node.addEventListener('click', closeReleaseModal);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || releaseModalOverlay?.hidden !== false) return;

      event.preventDefault();
      closeReleaseModal();
    });

    document.addEventListener('click', (event) => {
      const link = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>('a[href^="#"]') : null;
      if (!link || link.closest('[data-navbar-smooth-scroll]')) return;

      const url = new URL(link.href);
      if (url.pathname !== window.location.pathname || url.hash.length <= 1) return;

      event.preventDefault();
      scrollToHash(url.hash);
    }, { capture: true });

    window.addEventListener('hashchange', () => scrollToHash(window.location.hash, false));

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        switchLanguage(document.documentElement.lang === 'ru' ? 'en' : 'ru');
      });
    });

    window.addEventListener('elizgrome:set-language', (event) => {
      const lang = 'detail' in event && event.detail === 'ru' ? 'ru' : 'en';
      setLanguage(lang);
    });

    setLanguage(localStorage.getItem('elizgrome-lang') === 'ru' ? 'ru' : 'en');
    updateReleaseTimeline();
    window.setTimeout(() => {
      scrollToHash(window.location.hash, false);
      updateReleaseTimeline();
    }, 0);
  </script>
</Layout>
