---
import YAML from 'yaml';
import { ContactIconCloud } from './ContactIconCloud';
import { MerchCarousel } from './MerchCarousel';
import { SiteNavbar } from './SiteNavbar';
import landingRaw from '../content/landing.yaml?raw';
import logoSvg from '../assets/images/liza-logo.svg?raw';
import arrowTip from '../../arrow-tip.svg?url';
import { mergeLandingData, type CmsLanding, type Lang, type Localized } from '../data/landing-internal';
import Layout from '../layouts/Layout.astro';

const data = mergeLandingData(YAML.parse(landingRaw) as CmsLanding);
const images = import.meta.glob('../assets/images/*.{jpg,jpeg,png}', {
  eager: true,
  import: 'default',
}) as Record<string, ImageMetadata>;

function imageSrc(path: string) {
  const key = path.replace('src/assets/images/', '../assets/images/');
  return images[key]?.src ?? path;
}

function localAttrs(value: Localized) {
  return {
    'data-i18n-en': value.en,
    'data-i18n-ru': value.ru,
  };
}

const about = data.sections.about;
const releases = data.sections.releases;
const concerts = data.sections.concerts;
const merch = data.sections.merch;
const contacts = data.sections.contacts;
const lang = 'en' as Lang;

const shirts = merch.groups.shirts.items.map((item) => ({
  ...item,
  image: imageSrc(item.image),
}));
const vinyl = merch.groups.vinyl.items.map((item) => ({
  ...item,
  image: imageSrc(item.image),
}));
const releaseYears = Array.from(new Set(releases.items.map((item) => item.year)))
  .sort((a, b) => Number(a) - Number(b));
const earlyReleaseYears = releaseYears.filter((year) => Number(year) < 2024);
const latestReleaseYears = releaseYears.filter((year) => Number(year) >= 2024);
const earlyDotPositions = [0.14, 0.3, 0.45, 0.67, 0.8, 0.92];
const latestDotPositions = [0.42, 0.68, 0.8];
const timelineDots = [
  {
    id: 'ozera',
    year: '2016-2017',
    title: { en: 'ОЗЁРА', ru: 'ОЗЁРА' },
    page: 0,
    position: earlyDotPositions[0],
  },
  ...earlyReleaseYears.map((year, index) => ({
    id: `release-year-${year}`,
    year,
    title: null,
    page: 0,
    position: earlyDotPositions[index + 1] ?? 0.92,
  })),
  ...latestReleaseYears.map((year, index) => ({
    id: `release-year-${year}`,
    year,
    title: null,
    page: 1,
    position: latestDotPositions[index] ?? 0.84,
  })),
];

---

<Layout seo={data.site.seo}>
  <div id="top" class="min-h-screen overflow-x-clip bg-background text-foreground">
    <SiteNavbar
      client:load
      logo={data.site.navigation.logo}
      logoSvg={logoSvg}
      menuLabel={data.site.navigation.menu_label}
      searchLabel={data.site.navigation.search_label}
      languageLabel={data.site.navigation.language_label}
      promoPack={data.site.navigation.promo_pack}
      sectionLinks={data.site.navigation.section_links}
      searchSongs={data.search.songs}
    />

    <main>
      <section id="about" class="relative min-h-svh scroll-mt-11 overflow-hidden bg-background md:h-svh md:scroll-mt-12">
        <picture>
          <source media="(min-width: 768px)" srcset={imageSrc(about.hero.desktop)} />
          <img
            src={imageSrc(about.hero.mobile)}
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
          />
        </picture>
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/75 via-black/30 via-40% to-transparent"
          aria-hidden="true"
        ></div>
        <div class="pointer-events-none absolute inset-0 bg-white/15" aria-hidden="true"></div>
        <div class="about-hero-copy relative z-10 flex min-h-svh flex-col px-5 pb-8 pt-26 text-white md:h-svh md:px-10 md:pt-28">
          <div class="mt-auto max-w-2xl">
            <h2
              id="about-title"
              class="font-heading text-5xl leading-none font-bold text-white md:text-6xl"
              {...localAttrs(about.title)}
            >
              {about.title[lang]}
            </h2>
            <p
              class="mt-4 max-w-xl font-serif text-lg leading-tight md:text-2xl"
              {...localAttrs(about.text)}
            >
              {about.text[lang]}
            </p>
          </div>
        </div>
      </section>

      <section id="releases" class="releases-section min-h-svh scroll-mt-11 bg-background px-5 py-7 md:scroll-mt-12 md:px-10 md:py-8 lg:h-[200svh] lg:scroll-mt-0 lg:overflow-visible lg:px-0 lg:py-0">
        <div class="lg:hidden">
          <h2 class="font-heading text-5xl leading-none font-bold md:text-6xl" {...localAttrs(releases.title)}>
            {releases.title[lang]}
          </h2>
        </div>

        <div class="mt-7 grid gap-12 sm:px-8 lg:hidden">
          {releases.items.map((item) => (
            <article
              class:list={[
                'items-center justify-between gap-7 sm:gap-10 md:gap-8',
                item.image
                  ? 'grid grid-cols-[minmax(0,18.75rem)_8.5rem] sm:grid-cols-[18.75rem_13rem] md:grid-cols-[18.75rem_18rem]'
                  : 'grid grid-cols-[5rem_minmax(0,1fr)]',
              ]}
            >
              {item.image ? (
                <a href="#contacts" class="block no-underline hover:no-underline">
                  <div class="rounded-md bg-background shadow-[0_18px_45px_rgb(0_0_0/0.12)]">
                    <img src={imageSrc(item.image)} alt={item.title[lang]} class="aspect-square w-full max-w-[18.75rem] rounded-md object-cover" loading="lazy" />
                  </div>
                </a>
              ) : (
                <p class="font-heading text-3xl leading-none text-foreground">
                  <span>{item.year}</span>
                </p>
              )}
              <div class={item.image ? 'text-right sm:pr-2' : 'min-w-0'}>
                {item.image && (
                  <p class="relative inline-block font-heading text-4xl leading-none text-foreground">
                    <span>{item.year}</span>
                  </p>
                )}
                <p class="mt-1 font-serif text-base leading-tight text-foreground sm:text-lg" {...localAttrs(item.title)}>
                  {item.title[lang]}
                </p>
              </div>
            </article>
          ))}
        </div>

        <div class="releases-timeline-sticky hidden lg:block">
          <h2 class="releases-timeline-title font-heading text-6xl leading-none font-bold" {...localAttrs(releases.title)}>
            {releases.title[lang]}
          </h2>

          <div class="releases-timeline-viewport" aria-label={releases.title[lang]}>
            <div class="releases-timeline-track">
              <div class="releases-timeline-start" aria-hidden="true"></div>
              <div class="releases-timeline-line" aria-hidden="true"></div>
              <div class="releases-timeline-dots">
                {timelineDots.map((dot) => (
                  <div
                    class="releases-timeline-dot"
                    style={`--dot-page:${dot.page}; --dot-position:${dot.position};`}
                    aria-label={dot.title ? `${dot.title[lang]} ${dot.year}` : dot.year}
                  >
                    <span class="releases-timeline-dot-label">
                      {dot.title && (
                        <span class="releases-timeline-dot-title" {...localAttrs(dot.title)}>
                          {dot.title[lang]}
                        </span>
                      )}
                      <span class="releases-timeline-dot-year">{dot.year}</span>
                    </span>
                    <span class="releases-timeline-dot-mark" aria-hidden="true"></span>
                  </div>
                ))}
              </div>
              <img src={arrowTip} alt="" class="releases-timeline-arrow" aria-hidden="true" />
            </div>
          </div>
        </div>
      </section>

      <section id="concerts" class="min-h-svh scroll-mt-11 bg-background px-5 py-7 md:h-svh md:scroll-mt-12 md:overflow-hidden md:px-10 md:py-8">
        <h2 class="font-heading text-5xl leading-none font-bold md:text-6xl" {...localAttrs(concerts.title)}>
          {concerts.title[lang]}
        </h2>
        <div class="relative mt-4 min-h-[calc(100svh-9rem)] md:h-[calc(100%-4rem)] md:min-h-0">
          {concerts.items.map((item) => {
            const mobile = item.layout.mobile;
            const desktop = item.layout.desktop;
            return (
              <Fragment>
                <div
                  class:list={[
                    'absolute md:hidden',
                    item.style === 'primary' ? 'w-[12rem]' : 'w-[9.5rem]',
                  ]}
                  style={`left:${mobile.x}%; top:${mobile.y}%;`}
                >
                  {item.url ? (
                    <a href={item.url} class="block no-underline hover:text-primary hover:no-underline">
                      <span
                        class:list={[
                          'block font-serif leading-tight text-foreground',
                          item.style === 'primary' ? 'text-2xl' : 'text-xl text-primary',
                        ]}
                        {...localAttrs(item.title)}
                      >
                        {item.title[lang]}
                      </span>
                    </a>
                  ) : (
                    <span
                      class:list={[
                        'block font-serif leading-tight text-muted-foreground line-through',
                        item.style === 'primary' ? 'text-2xl' : 'text-xl',
                      ]}
                      {...localAttrs(item.title)}
                    >
                      {item.title[lang]}
                    </span>
                  )}
                </div>
                <div
                  class:list={[
                    'absolute hidden md:block',
                    item.style === 'primary' ? 'w-[18rem]' : 'w-[14rem]',
                  ]}
                  style={`left:${desktop.x}%; top:${desktop.y}%;`}
                >
                  {item.url ? (
                    <a href={item.url} class="block no-underline hover:text-primary hover:no-underline">
                      <span
                        class:list={[
                          'block font-serif leading-tight text-foreground',
                          item.style === 'primary' ? 'text-4xl' : 'text-2xl text-primary',
                        ]}
                        {...localAttrs(item.title)}
                      >
                        {item.title[lang]}
                      </span>
                    </a>
                  ) : (
                    <span
                      class:list={[
                        'block font-serif leading-tight text-muted-foreground line-through',
                        item.style === 'primary' ? 'text-4xl' : 'text-2xl',
                      ]}
                      {...localAttrs(item.title)}
                    >
                      {item.title[lang]}
                    </span>
                  )}
                </div>
              </Fragment>
            );
          })}
        </div>
      </section>

      <section id="merch" class="merch-section min-h-svh scroll-mt-11 bg-background px-5 py-7 md:h-[calc(100svh-3rem)] md:min-h-0 md:scroll-mt-12 md:overflow-hidden md:px-0 md:py-0">
        <div class="merch-stage relative mx-auto h-full md:mx-0 md:max-w-none">
          <h2 class="merch-title font-heading text-5xl leading-none font-bold md:text-5xl lg:text-6xl" {...localAttrs(merch.title)}>
            {merch.title[lang]}
          </h2>

          <div class="merch-categories mt-6 hidden gap-2 md:mt-0 md:grid md:w-28 lg:w-32">
            <span class="font-serif text-sm leading-tight text-foreground lg:text-base" {...localAttrs(merch.groups.shirts.title)}>
              {merch.groups.shirts.title[lang]}
            </span>
            <span class="font-serif text-sm leading-tight text-foreground lg:text-base" {...localAttrs(merch.groups.vinyl.title)}>
              {merch.groups.vinyl.title[lang]}
            </span>
            <span class="font-serif text-sm leading-tight text-foreground lg:text-base" {...localAttrs(merch.groups.picks.title)}>
              {merch.groups.picks.title[lang]}
            </span>
          </div>

          <div id="merch-shirts" class="merch-shirts mt-8 md:mt-0">
            <h3 class="mb-3 font-serif text-xl leading-tight text-foreground md:hidden" {...localAttrs(merch.groups.shirts.title)}>
              {merch.groups.shirts.title[lang]}
            </h3>
            <MerchCarousel client:load items={shirts} lang={lang} desktopSingle fillHeight />
          </div>

          <div id="merch-vinyl" class="mt-10 md:hidden">
            <h3 class="mb-3 font-serif text-xl leading-tight text-foreground" {...localAttrs(merch.groups.vinyl.title)}>
              {merch.groups.vinyl.title[lang]}
            </h3>
            <MerchCarousel client:load items={vinyl} lang={lang} aspect="square" />
          </div>

          <div class="merch-vinyl-stripe hidden md:grid md:grid-cols-7 md:items-end md:gap-0">
            {vinyl.map((item) => (
              <figure>
                <img src={item.image} alt={item.alt[lang]} class="aspect-square w-full object-cover" loading="lazy" />
              </figure>
            ))}
          </div>

          <a
            href={merch.order_link.url}
            class="merch-order mx-auto mt-8 block w-fit font-serif text-2xl leading-tight text-foreground no-underline underline-offset-4  md:mx-0 md:mt-0 md:text-3xl lg:text-4xl hover:underline transition-all"
            {...localAttrs(merch.order_link.label)}
          >
            {merch.order_link.label[lang]}
        </a>
        </div>
      </section>

      <section id="contacts" class="h-[calc(100svh-2.75rem)] overflow-hidden scroll-mt-11 bg-background px-5 py-7 md:h-[calc(100svh-3rem)] md:scroll-mt-12 md:px-10 md:pb-8 md:pt-[31px]">
        <div class="relative h-full">
          <h2 class="font-heading text-5xl leading-none font-bold md:text-6xl" {...localAttrs(contacts.title)}>
            {contacts.title[lang]}
          </h2>
          <ContactIconCloud client:load links={contacts.links} />
        </div>
      </section>
    </main>
  </div>

  <style>
    @media (min-width: 1024px) {
      .releases-section {
        --release-progress: 0;
        --releases-timeline-pad: 10rem;
        --releases-page-w: calc(100vw - var(--releases-timeline-pad));
        --releases-scroll-w: calc(120vw - var(--releases-timeline-pad));
      }

      .releases-timeline-sticky {
        position: sticky;
        top: 0;
        z-index: 1;
        height: 100svh;
        overflow: hidden;
        background: var(--background);
      }

      .releases-timeline-title {
        position: absolute;
        left: 2.5rem;
        top: 5rem;
        z-index: 2;
      }

      .releases-timeline-viewport {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
      }

      .releases-timeline-track {
        position: absolute;
        left: var(--releases-timeline-pad);
        top: 50%;
        height: 0;
        width: calc(200vw - (var(--releases-timeline-pad) * 2));
        transform: translate3d(calc(var(--release-progress) * -1 * var(--releases-scroll-w)), 0, 0);
        will-change: transform;
      }

      .releases-timeline-line {
        position: absolute;
        left: 0.5rem;
        right: 20rem;
        top: 0;
        height: 2px;
        background: var(--foreground);
      }

      .releases-timeline-dots {
        position: absolute;
        inset: 0;
      }

      .releases-timeline-dot {
        position: absolute;
        left: calc(
          (var(--dot-page) * var(--releases-page-w)) +
          (var(--dot-position) * (var(--releases-page-w) - 7rem)) +
          2rem
        );
        top: 0;
        display: grid;
        justify-items: center;
        transform: translateX(-50%);
      }

      .releases-timeline-dot-label {
        display: grid;
        justify-items: center;
        gap: 0.3rem;
        transform: translateY(calc(-100% - 1.2rem));
        color: var(--primary);
        font-family: var(--site-font-family);
        font-weight: 500;
        line-height: 1;
        text-align: center;
        white-space: nowrap;
      }

      .releases-timeline-dot-title {
        font-size: 0.88rem;
        letter-spacing: 0;
      }

      .releases-timeline-dot-year {
        font-family: var(--site-font-family);
        font-size: 1rem;
        font-weight: 400;
        letter-spacing: 0;
      }

      .releases-timeline-dot-mark {
        position: absolute;
        left: 50%;
        top: 0;
        height: 1rem;
        width: 1rem;
        transform: translate(-50%, -50%);
        border-radius: 9999px;
        background: var(--foreground);
      }

      .releases-timeline-start {
        position: absolute;
        left: 0;
        top: 0;
        z-index: 1;
        height: 0.875rem;
        width: 0.875rem;
        transform: translateY(-50%);
        border: 2px solid var(--foreground);
        border-radius: 9999px;
        background: var(--background);
      }

      .releases-timeline-arrow {
        position: absolute;
        right: 20rem;
        top: 0;
        /* arrow tip size */
        width: 1.5rem;
        height: 1.5rem;
        transform: translate(50%, -50%) rotate(90deg);
      }

    }

    @media (min-width: 768px) {
      .merch-stage {
        --merch-section-h: calc(100svh - 3rem);
        --merch-pad: clamp(1rem, 3svh, 2rem);
        --vinyl-size: calc(100vw / 7);
        --carousel-top: var(--merch-pad);
        --carousel-bottom: var(--merch-pad);
        --carousel-h: min(
          clamp(24rem, 66svh, 40rem),
          calc(var(--merch-section-h) - var(--vinyl-size) - var(--carousel-top) - var(--carousel-bottom))
        );
        --carousel-w: min(
          calc(var(--carousel-h) * 0.8),
          56vw,
          calc(100vw - (var(--merch-pad) * 2) - 20rem)
        );
        --diagonal-gap: clamp(1.75rem, 4vw, 4.5rem);
      }

      .merch-title {
        position: absolute;
        left: calc(var(--merch-pad) + var(--carousel-w) + var(--diagonal-gap));
        top: var(--carousel-top);
        max-width: calc(100vw - var(--merch-pad) - var(--carousel-w) - var(--diagonal-gap));
      }

      .merch-shirts {
        position: absolute;
        left: var(--merch-pad);
        top: var(--carousel-top);
        height: var(--carousel-h);
        width: var(--carousel-w);
        min-height: 0;
      }

      .merch-categories {
        position: absolute;
        left: calc(var(--merch-pad) + var(--carousel-w) + ((100vw - var(--merch-pad) - var(--carousel-w)) / 2));
        top: calc((100% - var(--vinyl-size)) * 0.48);
        transform: translate(-50%, -50%);
      }

      .merch-order {
        position: absolute;
        right: var(--merch-pad);
        bottom: calc(var(--vinyl-size) + var(--diagonal-gap));
      }

      .merch-vinyl-stripe {
        position: absolute;
        inset-inline: 0;
        bottom: 0;
        height: var(--vinyl-size);
        width: 100vw;
      }

      .merch-vinyl-stripe figure,
      .merch-vinyl-stripe img {
        height: 100%;
      }
    }
  </style>

  <script>
    type Lang = 'en' | 'ru';

    const translated = document.querySelectorAll<HTMLElement>('[data-i18n-en][data-i18n-ru]');
    const toggles = document.querySelectorAll<HTMLElement>('[data-language-toggle]');
    const releasesSection = document.querySelector<HTMLElement>('.releases-section');
    const desktopTimelineQuery = window.matchMedia('(min-width: 1024px)');
    let releaseTimelineFrame = 0;

    function setLanguage(lang: Lang) {
      document.documentElement.lang = lang;
      localStorage.setItem('elizgrome-lang', lang);

      translated.forEach((node) => {
        if (node.closest('header')) return;

        node.textContent = node.dataset[`i18n${lang === 'ru' ? 'Ru' : 'En'}`] || '';
      });

      document.querySelectorAll<HTMLMetaElement>('[data-seo-description], [data-seo-description-og]').forEach((node) => {
        node.content = node.dataset[lang] || node.content;
      });
      document.querySelectorAll<HTMLMetaElement>('[data-seo-title]').forEach((node) => {
        node.content = node.dataset[lang] || node.content;
      });
      const title = document.querySelector<HTMLTitleElement>('[data-page-title]');
      if (title) title.textContent = title.dataset[lang] || title.textContent;
    }

    function switchLanguage(lang: Lang) {
      setLanguage(lang);
      window.dispatchEvent(new CustomEvent('elizgrome:set-language', { detail: lang }));
    }

    function scaleValue(value: number, from: [number, number], to: [number, number]) {
      const scale = (to[1] - to[0]) / (from[1] - from[0]);
      const capped = Math.min(from[1], Math.max(from[0], value)) - from[0];

      return capped * scale + to[0];
    }

    function animateValue(targetElement: HTMLElement | null, scrollPercentage: [number, number], animateRange: [number, number]) {
      if (!targetElement) return 0;

      return scaleValue(
        ((window.scrollY - targetElement.offsetTop) / targetElement.clientHeight) * 100,
        scrollPercentage,
        animateRange,
      );
    }

    function updateReleaseTimeline() {
      if (!releasesSection) return;

      if (!desktopTimelineQuery.matches) {
        releasesSection.style.removeProperty('--release-progress');
        return;
      }

      releasesSection.style.setProperty(
        '--release-progress',
        animateValue(releasesSection, [0, 50], [0, 1]).toString(),
      );
    }

    function queueReleaseTimelineUpdate() {
      if (releaseTimelineFrame) return;

      releaseTimelineFrame = window.requestAnimationFrame(() => {
        releaseTimelineFrame = 0;
        updateReleaseTimeline();
      });
    }

    function setScrollTop(top: number) {
      const scrollingElement = document.scrollingElement || document.documentElement;

      scrollingElement.scrollTop = top;
      document.documentElement.scrollTop = top;
      document.body.scrollTop = top;
    }

    function scrollToHash(hash: string, updateHistory = true) {
      const id = hash.replace(/^#/, '');
      if (!id) return;

      const target = document.getElementById(id);
      if (!target) return;

      const scrollMarginTop = Number.parseFloat(window.getComputedStyle(target).scrollMarginTop) || 0;
      const top = target.getBoundingClientRect().top + window.scrollY - scrollMarginTop;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduceMotion) {
        setScrollTop(top);
      } else {
        window.scrollTo({ top, behavior: 'smooth' });
      }

      if (updateHistory) window.history.pushState(null, '', `#${id}`);
    }

    window.addEventListener('scroll', queueReleaseTimelineUpdate, { passive: true });
    window.addEventListener('resize', queueReleaseTimelineUpdate);
    desktopTimelineQuery.addEventListener('change', queueReleaseTimelineUpdate);

    document.addEventListener('click', (event) => {
      const link = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>('a[href^="#"]') : null;
      if (!link || link.closest('[data-navbar-smooth-scroll]')) return;

      const url = new URL(link.href);
      if (url.pathname !== window.location.pathname || url.hash.length <= 1) return;

      event.preventDefault();
      scrollToHash(url.hash);
    }, { capture: true });

    window.addEventListener('hashchange', () => scrollToHash(window.location.hash, false));

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        switchLanguage(document.documentElement.lang === 'ru' ? 'en' : 'ru');
      });
    });

    window.addEventListener('elizgrome:set-language', (event) => {
      const lang = 'detail' in event && event.detail === 'ru' ? 'ru' : 'en';
      setLanguage(lang);
    });

    setLanguage(localStorage.getItem('elizgrome-lang') === 'ru' ? 'ru' : 'en');
    updateReleaseTimeline();
    window.setTimeout(() => {
      scrollToHash(window.location.hash, false);
      updateReleaseTimeline();
    }, 0);
  </script>
</Layout>
