---
import YAML from 'yaml';
import { SiteNavbar } from '../components/SiteNavbar';
import landingRaw from '../content/landing.yaml?raw';
import Layout from '../layouts/Layout.astro';

type Lang = 'en' | 'ru';
type Localized = Record<Lang, string>;

type Landing = {
  site: {
    seo: {
      title: Localized;
      description: Localized;
    };
    navigation: {
      logo: Localized;
      menu_label: Localized;
      search_label: Localized;
      section_links: { target: string; label: Localized }[];
      external_links: { url: string; label: Localized }[];
    };
  };
  sections: Record<string, { title?: Localized }>;
};

const data = YAML.parse(landingRaw) as Landing;
const sections = data.site.navigation.section_links.map((link) => {
  const id = link.target.replace(/^#/, '');

  return {
    id,
    title: data.sections[id]?.title ?? link.label,
  };
});
---

<Layout seo={data.site.seo}>
  <div id="top" class="min-h-screen overflow-x-hidden bg-background">
    <SiteNavbar
      client:load
      logo={data.site.navigation.logo}
      menuLabel={data.site.navigation.menu_label}
      searchLabel={data.site.navigation.search_label}
      sectionLinks={data.site.navigation.section_links}
      externalLinks={data.site.navigation.external_links}
    />
    <main class="pt-12 md:pt-18">
      {sections.map((section) => (
        <section id={section.id} class="min-h-screen w-screen scroll-mt-12 border-b border-border bg-background px-4 py-8 md:scroll-mt-18 md:px-8 md:py-10">
          <h2
            class="font-heading text-6xl font-bold tracking-wide text-foreground md:text-8xl"
            data-i18n-en={section.title.en}
            data-i18n-ru={section.title.ru}
          >
            {section.title.en}
          </h2>
        </section>
      ))}
    </main>
  </div>

  <script>
    type Lang = 'en' | 'ru';

    const translated = document.querySelectorAll<HTMLElement>('[data-i18n-en][data-i18n-ru]');

    function setLanguage(lang: Lang) {
      document.documentElement.lang = lang;

      translated.forEach((node) => {
        node.textContent = node.dataset[`i18n${lang === 'ru' ? 'Ru' : 'En'}`] || '';
      });
    }

    setLanguage(localStorage.getItem('elizgrome-lang') === 'ru' ? 'ru' : 'en');
  </script>
</Layout>
